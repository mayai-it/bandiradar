# BandiRadar environment (copy to .env; .env is gitignored).
# The repo runs fully OFFLINE on --sample data with ZERO secrets.
#
# A provider + key is needed for TWO live (non-sample) paths:
#   1. Stage-2 LLM relevance scoring (otherwise the deterministic offline
#      heuristic is used);
#   2. the Toscana LLM-assisted scraper's LIVE fetch, which extracts fields from
#      each bando's HTML page (its --sample path replays a recorded extraction and
#      needs no key).

# Which LLM provider to use. One of: anthropic | openai | none
# (default: none -> deterministic offline fallback for scoring; Toscana live
# fetch is unavailable without a provider, but `--source toscana --sample` works).
BANDIRADAR_LLM_PROVIDER=none

# Optional model override (else a sensible per-provider default is used).
# BANDIRADAR_LLM_MODEL=

# Provider API keys (only read when the matching provider above is set).
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
