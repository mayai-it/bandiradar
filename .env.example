# BandiRadar environment (copy to .env; .env is gitignored).
# The repo runs fully OFFLINE on --sample data with ZERO secrets.
# These are only needed to enable the Stage-2 LLM matcher against a live provider.

# Which LLM provider to use for Stage-2 relevance scoring.
# One of: anthropic | openai | none   (default: none -> deterministic offline fallback)
BANDIRADAR_LLM_PROVIDER=none

# Optional model override (else a sensible per-provider default is used).
# BANDIRADAR_LLM_MODEL=

# Provider API keys (only read when the matching provider above is set).
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
